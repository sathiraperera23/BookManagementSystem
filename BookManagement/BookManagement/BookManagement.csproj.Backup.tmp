<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<GenerateAssemblyInfo>false</GenerateAssemblyInfo>
	</PropertyGroup>

	<ItemGroup>
		<!-- OpenAPI / Swagger -->
		<PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.3" />
		<PackageReference Include="Swashbuckle.AspNetCore" Version="6.7.0" />

		<!-- PostgreSQL ADO.NET provider -->
		<PackageReference Include="Npgsql" Version="7.0.0" />

		<!-- Logging abstraction -->
		<PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="7.0.0" />
	</ItemGroup>

	<ItemGroup>
		<!-- Project references -->
		<ProjectReference Include="..\BookManagement.Application\BookManagement.Application.csproj" />
		<ProjectReference Include="..\BookManagement.Domain\BookManagement.Domain.csproj" />
		<ProjectReference Include="..\BookManagement.Infrastructure\BookManagement.Infrastructure.csproj" />
	</ItemGroup>

</Project>